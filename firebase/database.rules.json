{
  "rules": {
    "departures": {
      ".read": "auth != null",
      ".indexOn": ["siteId", "status", "materialType", "departureTime", "createdAt"],
      "$departureId": {
        ".write": "auth != null"
      }
    },
    "sites": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "users": {
      ".read": "auth != null",
      "$userId": {
        ".write": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "attendance": {
      ".read": "auth != null",
      ".indexOn": ["siteId", "checkInTime"],
      "$recordId": {
        ".write": "auth != null"
      }
    },
    "stats": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
